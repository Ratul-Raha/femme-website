# Server Configuration
PORT=6000
NODE_ENV=development

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/femme
# Example Atlas URI: mongodb+srv://<username>:<password>@cluster.mongodb.net/femme?retryWrites=true&w=majority

# JWT Secret Key
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# File Upload Settings
MAX_FILE_SIZE=10485760